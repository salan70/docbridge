{
  "name": "speclink",
  "version": "0.3.0",
  "description": "A Bun CLI that links Markdown specifications and code declarations.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "speclink": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/salan70/spec-link.git"
  },
  "bugs": {
    "url": "https://github.com/salan70/spec-link/issues"
  },
  "homepage": "https://github.com/salan70/spec-link#readme",
  "keywords": [
    "documentation",
    "markdown",
    "specification",
    "cli",
    "bun",
    "lsp"
  ],
  "engines": {
    "bun": ">=1.1.31"
  },
  "files": [
    "dist",
    "schemas",
    "templates/skills",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "speclink": "bun run src/cli/index.ts",
    "check": "bun run src/cli/index.ts check",
    "check:example": "bun run src/cli/index.ts check --root examples/typescript",
    "test": "bun test",
    "build": "bun build src/cli/index.ts --outdir dist --target bun"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.0"
  }
}
