{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/session-start.sh\"",
            "timeout": 5,
            "statusMessage": "Loading SpecLink reminders"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/stop-verify.sh\"",
            "timeout": 300,
            "statusMessage": "Running SpecLink final checks"
          }
        ]
      }
    ]
  }
}
