{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/session-start.sh\"",
            "timeout": 5,
            "statusMessage": "Loading DocBridge reminders"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/on-edit-context.sh\"",
            "timeout": 30,
            "statusMessage": "Fetching DocBridge counterpart context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/stop-verify.sh\"",
            "timeout": 300,
            "statusMessage": "Running DocBridge verification"
          }
        ]
      }
    ]
  }
}
