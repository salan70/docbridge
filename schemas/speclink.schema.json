{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SpecLink Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["include"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "include": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "docs"],
      "properties": {
        "code": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "docs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
