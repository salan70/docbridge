{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DocBridge Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["include"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "include": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "docs"],
      "properties": {
        "code": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "typescript": { "$ref": "#/$defs/codeLanguageEntry" },
            "swift": { "$ref": "#/$defs/codeLanguageEntry" },
            "dart": { "$ref": "#/$defs/codeLanguageEntry" }
          }
        },
        "docs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "codeLanguageEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["patterns"],
      "properties": {
        "patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "visibility": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
