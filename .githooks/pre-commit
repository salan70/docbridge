#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

run_just() {
  if command -v just >/dev/null 2>&1; then
    just "$@"
  else
    nix develop -c just "$@"
  fi
}

echo "Running pre-commit guard: just check"
run_just check

echo "Running pre-commit guard: just test"
run_just test
