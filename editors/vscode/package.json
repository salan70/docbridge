{
  "name": "docbridge-vscode",
  "private": true,
  "displayName": "DocBridge",
  "description": "Minimal VS Code client that launches and exercises the DocBridge language server.",
  "version": "0.2.0",
  "publisher": "docbridge",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "DocBridge",
      "properties": {
        "docbridge.bunPath": {
          "type": "string",
          "default": "bun",
          "description": "Path to the Bun executable used to launch `docbridge lsp`."
        },
        "docbridge.cliPath": {
          "type": "string",
          "description": "Optional absolute path to the DocBridge CLI entrypoint. Defaults to the server bundled with this extension."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.84.0",
    "typescript": "^5.9.0"
  }
}
